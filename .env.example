# ── Pulse backend environment ─────────────────────────────────────────────
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored (never commit real secrets). This file is the template.

# ── Server ─────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── JWT ────────────────────────────────────────────────────────────────────
# Generate strong random secrets:  openssl rand -hex 32
# IMPORTANT: secrets must NOT contain a `$` — Docker Compose interpolates `$word`
# in env_file values and would blank it. Use plain hex/base64.
ACCESS_SECRETKEY=replace_me_openssl_rand_hex_32
REFRESH_SECRETKEY=replace_me_openssl_rand_hex_32
# Expiries MUST include a unit (e.g. 15m, 12h, 7d). A bare number is parsed as ms.
ACCESS_EXPIRY=15m
REFRESH_EXPIRY=7d

# ── Datastores ───────────────────────────────────────────────────────────────
# Values below are for running the server on the HOST against the compose db/redis
# (ports 5434 / 6379). NOTE: `docker compose` overrides these so the backend
# container reaches the db/redis CONTAINERS by service name (db:5432, redis:6379).
DATABASE_URL=postgres://postgres:admin@localhost:5434/postgres
REDIS_URL=redis://localhost:6379

# ── Mail (SMTP — e.g. Mailtrap sandbox) ──────────────────────────────────────
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_smtp_user
MAIL_PASSWORD=your_smtp_password

# ── Allowlists for client-supplied email link bases (exact match) ────────────
# The frontend sends verifyBase/resetBase; the backend accepts them only if listed.
# Must match the frontend origin + path (dev server is pinned to :5173).
ALLOWED_VERIFY_BASES=http://localhost:5173/verify
ALLOWED_RESET_BASES=http://localhost:5173/resetPassword

# ── Amazon S3 (cookie-policy image storage) ──────────────────────────────────
# Images are stored in a PRIVATE S3 bucket; reads go through short-lived presigned
# URLs. Use the STANDARD AWS var names so the SDK's default provider chain finds them.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
S3_BUCKET=your-bucket-name
# Optional: presigned-URL lifetime in seconds (default 300).
# S3_PRESIGN_EXPIRY=300
# Optional: point at a local S3 (LocalStack/MinIO) instead of real AWS.
# S3_ENDPOINT=http://localhost:4566
